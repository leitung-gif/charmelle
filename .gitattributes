# Force LF line endings for all text files (Linux server compatibility)
* text=auto eol=lf
*.php text eol=lf
*.css text eol=lf
*.js text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.html text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
